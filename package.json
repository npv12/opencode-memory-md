{
  "name": "@npv12/opencode-memory-md",
  "version": "1.0.0",
  "description": "Simple markdown-based memory plugin for OpenCode",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky"
  },
  "keywords": [
    "opencode",
    "plugin",
    "memory",
    "markdown"
  ],
  "author": "npv12",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/npv12/opencode-memory-md.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@huggingface/transformers": "4.0.0-next.4",
    "@opencode-ai/plugin": "^1.2.6",
    "vectra": "^0.12.3"
  },
  "overrides": {
    "onnxruntime-node": "1.23.2"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/bun": "^1.3.8",
    "@types/node": "^22.19.11",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "opencode": {
    "type": "plugin"
  },
  "files": [
    "dist"
  ]
}
